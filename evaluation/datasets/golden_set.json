  "notes": "Values represent expected ranges for validation. Update periodically as market conditions change.",
  "test_cases": [
    {
      "id": "ogdc_baseline",
      "symbol": "OGDC",
      "company_name": "Oil and Gas Development Company Limited",
      "sector": "Oil & Gas Exploration Companies",
      "description": "Largest E&P company in Pakistan by production",
      "expected": {
        "data_completeness": {
          "required_fields": [
            "quote.price",
            "quote.pe_ratio",
            "company.name",
            "company.sector",
            "financials",
            "ratios"
          ],
          "min_financials_rows": 5,
          "min_ratio_rows": 3
        },
        "valuation_ranges": {
          "pe_ratio": [5.0, 15.0],
          "pb_ratio": [0.5, 2.5],
          "dividend_yield_pct": [2.0, 10.0]
        },
        "recommendation_valid": ["STRONG_BUY", "BUY", "HOLD", "SELL", "STRONG_SELL"],
        "confidence_range": [0.3, 1.0]
      }
    },
